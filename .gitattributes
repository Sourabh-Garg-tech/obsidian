# Auto detect text files and perform LF normalization
* text=auto

# Windows batch and PowerShell scripts should always use CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Shell scripts should always use LF
*.sh text eol=lf

# Markdown files
*.md text

# JSON files
*.json text

# YAML files
*.yml text
*.yaml text

# Denote all files that are truly binary and should not be modified
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
